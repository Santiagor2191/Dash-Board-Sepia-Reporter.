# ====================================================================
# Configuracion del MCP Sepia MeLi
# Copia este archivo a .env y completa los valores. NUNCA subas .env a git.
# ====================================================================

# --- OAuth de Mercado Libre (mismo client_id/secret que el backend) ---
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=

# Redirect URI PUBLICO HTTPS para el MCP (MeLi rechaza HTTP).
# Aprovechamos el ngrok del backend: MeLi llama al backend, que reenvia a localhost.
# Esta URL hay que registrarla en developers.mercadolibre.com como URI adicional.
MCP_REDIRECT_URI=https://nontransposable-veda-unintrudingly.ngrok-free.dev/mcp-callback

# Puerto local donde authorize.js escucha el redirect (no expuesto)
MCP_AUTH_PORT=8765

# --- PostgreSQL (mismas credenciales del backend) ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=mercado_libre_oficial

# --- Opcional: ID del vendedor por defecto (si no, se consulta /users/me) ---
MELI_SELLER_ID=
